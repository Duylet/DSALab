    int original[] = { 3, -12, 14, 9, 11, -50, -100 };
    int n = 7;

    int choice;

    do {
        cout << "\n===== MENU SAP XEP =====\n";
        cout << "1. Selection Sort\n";
        cout << "2. Insertion Sort\n";
        cout << "3. Bubble Sort\n";
        cout << "4. Quick Sort\n";
        cout << "5. Heap Sort\n";
        cout << "0. Thoat\n";
        cout << "Chon: ";
        cin >> choice;

        // copy mang goc de moi lan chay khong bi thay doi
        int a[100];
        for (int i = 0; i < n; i++)
            a[i] = original[i];

        cout << "\nMang ban dau: ";
        printArray(a, n);
        cout << "Qua trinh sap xep:\n";

        switch (choice) {
        case 1:
            selectionSort(a, n);
            break;
        case 2:
            insertionSort(a, n);
            break;
        case 3:
            bubbleSort(a, n);
            break;
        case 4:
            quickSort(a, 0, n - 1);
            break;
        case 5:
            heapSort(a, n);
            break;
        }

        if (choice >= 1 && choice <= 5) {
            cout << "Ket qua cuoi: ";
            printArray(a, n);
        }

    } while (choice != 0);

    return 0;
}
